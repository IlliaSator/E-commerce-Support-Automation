APP_ENV=local
LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Minsk

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_URL=http://backend:8000

POSTGRES_DB=ecommerce_support
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_password
DATABASE_URL=postgresql+psycopg://ecommerce_user:ecommerce_password@postgres:5432/ecommerce_support

TELEGRAM_BOT_TOKEN=
MANAGER_CHAT_IDS=
TELEGRAM_POLLING_ENABLED=true

ADMIN_API_KEY=change-me-local-only

OPENAI_API_KEY=
LLM_ENABLED=false
AI_PROVIDER=local
AI_MODEL_NAME=local-mock

N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
